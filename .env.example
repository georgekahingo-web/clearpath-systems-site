# Copy to .env.local and set values (never commit real secrets).
#
# Stripe: use test keys (sk_test_… / pk_test_…) for local and preview;
# set live keys in production. The app infers test vs live from the secret key.

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_TEXTBACK_PRICE_ID=
STRIPE_STARTER_DEPOSIT_PRICE_ID=
STRIPE_GROWTH_DEPOSIT_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Optional: Text-Back internal notify (defaults in code if unset)
# TEXTBACK_INTERNAL_NOTIFY_EMAIL=

RESEND_API_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Base URL for Twilio webhooks (e.g. https://your-domain.com or http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
